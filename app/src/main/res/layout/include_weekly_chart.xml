<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Bars row: each day is a vertical LinearLayout with a bottom-aligned bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:orientation="horizontal"
        android:weightSum="7"
        android:gravity="bottom">

        <!-- Mon -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="bottom|center_horizontal">
            <View
                android:layout_width="18dp"
                android:layout_height="45dp"
                android:background="@drawable/bg_chart_bar_default" />
        </LinearLayout>

        <!-- Tue -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="bottom|center_horizontal">
            <View
                android:layout_width="18dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_chart_bar_default" />
        </LinearLayout>

        <!-- Wed - active/highlighted day -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="bottom|center_horizontal">
            <View
                android:layout_width="18dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_chart_bar_active" />
        </LinearLayout>

        <!-- Thu -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="bottom|center_horizontal">
            <View
                android:layout_width="18dp"
                android:layout_height="35dp"
                android:background="@drawable/bg_chart_bar_default" />
        </LinearLayout>

        <!-- Fri -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="bottom|center_horizontal">
            <View
                android:layout_width="18dp"
                android:layout_height="55dp"
                android:background="@drawable/bg_chart_bar_default" />
        </LinearLayout>

        <!-- Sat -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="bottom|center_horizontal">
            <View
                android:layout_width="18dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_chart_bar_default" />
        </LinearLayout>

        <!-- Sun -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="bottom|center_horizontal">
            <View
                android:layout_width="18dp"
                android:layout_height="25dp"
                android:background="@drawable/bg_chart_bar_default" />
        </LinearLayout>

    </LinearLayout>

    <!-- Day labels row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="7"
        android:layout_marginTop="8dp">

        <TextView style="@style/DayLabel" android:text="Mon" />
        <TextView style="@style/DayLabel" android:text="Tue" />
        <TextView style="@style/DayLabel" android:text="Wed" />
        <TextView style="@style/DayLabel" android:text="Thu" />
        <TextView style="@style/DayLabel" android:text="Fri" />
        <TextView style="@style/DayLabel" android:text="Sat" />
        <TextView style="@style/DayLabel" android:text="Sun" />

    </LinearLayout>

</LinearLayout>
