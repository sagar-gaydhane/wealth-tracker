<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    tools:context=".presentation.transactions.TransactionsFragment">

        <!--  ===== Top App Bar =====  -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="13dp"
            android:paddingTop="16dp"
            android:paddingEnd="13dp"
            android:paddingBottom="12dp"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivAvatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="@string/profile_avatar"
                android:scaleType="centerCrop"
                android:src="@drawable/avatar_placeholder"
                app:shapeAppearanceOverlay="@style/CircleImage" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/transactions"
                android:textColor="@color/primary_blue"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>
        <!--  ===== Filter chips =====  -->
        <HorizontalScrollView
            android:id="@+id/chipScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="4dp"
            android:scrollbars="none"
            app:layout_constraintTop_toBottomOf="@id/topBar">

            <LinearLayout
                android:id="@+id/chipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="13dp"
                android:paddingEnd="13dp">

                <TextView
                    android:id="@+id/chipAll"
                    style="@style/FilterChip"
                    android:background="@drawable/bg_chip_selected"
                    android:text="@string/filter_all"
                    android:textColor="@color/chip_text_selected" />

                <TextView
                    android:id="@+id/chipFood"
                    style="@style/FilterChip"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_food"
                    android:textColor="@color/chip_text_unselected" />

                <TextView
                    android:id="@+id/chipRent"
                    style="@style/FilterChip"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_rent"
                    android:textColor="@color/chip_text_unselected" />

                <TextView
                    android:id="@+id/chipTravel"
                    style="@style/FilterChip"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_travel"
                    android:textColor="@color/chip_text_unselected" />

                <TextView
                    android:id="@+id/chipTransport"
                    style="@style/FilterChip"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_transport"
                    android:textColor="@color/chip_text_unselected" />

                <TextView
                    android:id="@+id/chipShopping"
                    style="@style/FilterChip"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_shopping"
                    android:textColor="@color/chip_text_unselected" />

                <TextView
                    android:id="@+id/chipEntertainment"
                    style="@style/FilterChip"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_entertainment"
                    android:textColor="@color/chip_text_unselected" />

                <TextView
                    android:id="@+id/chipBills"
                    style="@style/FilterChip"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_bills"
                    android:textColor="@color/chip_text_unselected" />

                <TextView
                    android:id="@+id/chipHealth"
                    style="@style/FilterChip"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_health"
                    android:textColor="@color/chip_text_unselected" />

                <TextView
                    android:id="@+id/chipEducation"
                    style="@style/FilterChip"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_education"
                    android:textColor="@color/chip_text_unselected" />

                <TextView
                    android:id="@+id/chipBusiness"
                    style="@style/FilterChip"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_business"
                    android:textColor="@color/chip_text_unselected" />

                <TextView
                    android:id="@+id/chipGift"
                    style="@style/FilterChip"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_gift"
                    android:textColor="@color/chip_text_unselected" />

                <TextView
                    android:id="@+id/chipMobileRecharge"
                    style="@style/FilterChip"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_mobile_recharge"
                    android:textColor="@color/chip_text_unselected" />

                <TextView
                    android:id="@+id/chipElectronics"
                    style="@style/FilterChip"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_electronics"
                    android:textColor="@color/chip_text_unselected" />

                <TextView
                    android:id="@+id/chipPets"
                    style="@style/FilterChip"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_pets"
                    android:textColor="@color/chip_text_unselected" />

                <TextView
                    android:id="@+id/chipOthers"
                    style="@style/FilterChip"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_others"
                    android:textColor="@color/chip_text_unselected" />
            </LinearLayout>
        </HorizontalScrollView>
        <!--  ===== Transaction list ===== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTransactions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="13dp"
        android:paddingEnd="13dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/chipScroll" />

    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_transactions"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/chipScroll" />



    </androidx.constraintlayout.widget.ConstraintLayout>









