<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    tools:context=".presentation.transactions.TransactionsFragment">

        <!--  ===== Top App Bar =====  -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingTop="16dp"
            android:paddingEnd="20dp"
            android:paddingBottom="12dp"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivAvatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="@string/profile_avatar"
                android:scaleType="centerCrop"
                android:src="@drawable/avatar_placeholder"
                app:shapeAppearanceOverlay="@style/CircleImage" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/transactions"
                android:textColor="@color/primary_blue"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnSearch"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/search"
                android:src="@drawable/ic_search"
                app:tint="@color/text_primary" />
        </LinearLayout>
        <!--  ===== Filter chips =====  -->
        <HorizontalScrollView
            android:id="@+id/chipScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="4dp"
            android:scrollbars="none"
            app:layout_constraintTop_toBottomOf="@id/topBar">

            <LinearLayout
                android:id="@+id/chipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <TextView
                    android:id="@+id/chipAll"
                    style="@style/FilterChip"
                    android:background="@drawable/bg_chip_selected"
                    android:text="@string/filter_all"
                    android:textColor="@color/chip_text_selected" />

                <TextView
                    android:id="@+id/chipFood"
                    style="@style/FilterChip"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_food"
                    android:textColor="@color/chip_text_unselected" />

                <TextView
                    android:id="@+id/chipRent"
                    style="@style/FilterChip"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_rent"
                    android:textColor="@color/chip_text_unselected" />

                <TextView
                    android:id="@+id/chipTech"
                    style="@style/FilterChip"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_tech"
                    android:textColor="@color/chip_text_unselected" />

                <TextView
                    android:id="@+id/chipTravel"
                    style="@style/FilterChip"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected"
                    android:text="@string/filter_travel"
                    android:textColor="@color/chip_text_unselected" />
            </LinearLayout>
        </HorizontalScrollView>
        <!--  ===== Transaction list =====
                 Use a RecyclerView with two view types (item_date_header / item_transaction_row)
                 driven by a sectioned adapter. Static preview shown below via NestedScrollView.  -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollContent"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:paddingBottom="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/chipScroll">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">
                <!--  TODAY, OCT 24  -->
                <include layout="@layout/item_date_header" />
                <!--  Apple Subscription  -->
                <include layout="@layout/item_transaction_row" />
                <!--  Starbucks Coffee  -->
                <include layout="@layout/item_transaction_row" />
                <!--  YESTERDAY, OCT 23  -->
                <include layout="@layout/item_date_header" />
                <!--  Monthly Rent  -->
                <include layout="@layout/item_transaction_row" />
                <!--  OCT 21  -->
                <include layout="@layout/item_date_header" />
                <!--  Uber Trip  -->
                <include layout="@layout/item_transaction_row" />
                <!--  Joe's Pizza  -->
                <include layout="@layout/item_transaction_row" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>

